# App
APP_PORT=3000
APP_NAME=nest_js
NODE_ENV=production
APP_IMAGE=nest-js-app:local

# Auth
JWT_SECRET=change-me

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ecom
DB_USER=postgres
DB_PASS=change-me

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_EXCHANGE=orders.exchange
RABBITMQ_PROCESS_QUEUE=orders.process
RABBITMQ_RETRY_QUEUE=orders.retry
RABBITMQ_DLQ_QUEUE=orders.dlq
RABBITMQ_RETRY_DELAY_MS=3000
RABBITMQ_MAX_ATTEMPTS=3
RABBITMQ_PREFETCH=10

# Payments service (standalone process + future gRPC integration)
PAYMENTS_APP_PORT=3001
PAYMENTS_AUTHORIZE_DELAY_MS=0
# Use host.docker.internal when Orders runs in Docker and Payments runs on host.
PAYMENTS_GRPC_URL=host.docker.internal:50051
PAYMENTS_GRPC_BIND_URL=0.0.0.0:50051
PAYMENTS_GRPC_PROTO_PATH=proto/payments.proto
PAYMENTS_GRPC_PACKAGE=payments
PAYMENTS_GRPC_TIMEOUT_MS=1500

# AWS (optional)
AWS_REGION=eu-north-1
AWS_S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
