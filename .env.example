# App
APP_PORT=3000
APP_NAME=nest_js
NODE_ENV=production

# Auth
JWT_SECRET=change-me

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ecom
DB_USER=postgres
DB_PASS=change-me

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_EXCHANGE=orders.exchange
RABBITMQ_PROCESS_QUEUE=orders.process
RABBITMQ_RETRY_QUEUE=orders.retry
RABBITMQ_DLQ_QUEUE=orders.dlq
RABBITMQ_RETRY_DELAY_MS=3000
RABBITMQ_MAX_ATTEMPTS=3
RABBITMQ_PREFETCH=10

# AWS (optional)
AWS_REGION=eu-north-1
AWS_S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
